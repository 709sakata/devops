#!/bin/bash
# ============================================================
# 🤖 nightly-audit.sh (軽量版)
# 検出: grep + eslint（LLM不要）
# 生成: Ollama（Issue文章のみ・小さいコンテキスト）
# ============================================================

set -e

API_DIR="/Users/naokisakata/ghq/github.com/Hopin-inc/civicship-api"
PORTAL_DIR="/Users/naokisakata/ghq/github.com/Hopin-inc/civicship-portal"
LOG_DIR="$HOME/scripts/audit/logs"
DATE=$(date +"%Y-%m-%d")
OLLAMA_MODEL="qwen2.5-coder:14b"
OLLAMA_URL="http://127.0.0.1:11435/api/generate"

mkdir -p "$LOG_DIR"
LOG_FILE="$LOG_DIR/$DATE.log"

log() {
  echo "[$(date +'%H:%M:%S')] $1" | tee -a "$LOG_FILE"
}

# ============================================================
# Ollamaに短いプロンプトを投げてIssue文章を生成
# ============================================================
generate_issue_body() {
  local file="$1"
  local line="$2"
  local code="$3"
  local type="$4"  # "any_type" | "security" | "eslint"

  local prompt=""
  case "$type" in
    any_type)
      prompt="TypeScriptのコードレビューをしてください。
ファイル: $file
行番号: $line
問題のコード: $code

この箇所のany型の問題点と改善案を以下の形式で50文字以内で答えてください：
問題: （何が問題か1文）
改善案: （どう直すか1文）"
      ;;
    eslint)
      prompt="ESLintエラーの改善案を教えてください。
ファイル: $file
行番号: $line
エラー: $code

以下の形式で50文字以内で答えてください：
問題: （何が問題か1文）
改善案: （どう直すか1文）"
      ;;
    security)
      prompt="セキュリティ脆弱性の対応方針を教えてください。
パッケージ: $file
脆弱性: $code
修正バージョン: $line

以下の形式で答えてください：
問題: （リスクの概要1文）
対応: （pnpm updateコマンドを含む対応手順1文）"
      ;;
  esac

  curl -s "$OLLAMA_URL" \
    -H "Content-Type: application/json" \
    -d "{
      \"model\": \"$OLLAMA_MODEL\",
      \"prompt\": $(echo "$prompt" | jq -Rs .),
      \"stream\": false,
      \"options\": {
        \"temperature\": 0.1,
        \"num_ctx\": 1024,
        \"num_predict\": 200
      }
    }" | jq -r '.response // "生成失敗"'
}

# 既存IssueのタイトルリストをGitHubから取得
get_existing_titles() {
  local repo="$1"
  gh issue list \
    --repo "$repo" \
    --state open \
    --limit 200 \
    --json title \
    --jq '.[].title' 2>/dev/null | cat || echo ""
}

# Issueが既に存在するか確認（ファイルパスで判定）
issue_exists() {
  local existing_titles="$1"
  local file="$2"
  echo "$existing_titles" | grep -qF "$file"
}

log "🚀 nightly-audit 開始 ($DATE)"

# Ollamaが起動しているか確認
if ! curl -s "http://127.0.0.1:11434" > /dev/null 2>&1; then
  log "❌ Ollamaが起動していません。ollama serve を実行してください。"
  exit 1
fi
log "✅ Ollama接続確認OK"

# ============================================================
# 1. any型検出（grep）→ Issue起票
# ============================================================
for REPO_INFO in "Hopin-inc/civicship-api:$API_DIR" "Hopin-inc/civicship-portal:$PORTAL_DIR"; do
  REPO="${REPO_INFO%%:*}"
  DIR="${REPO_INFO##*:}"

  log "🔍 [$REPO] any型検出中..."
  cd "$DIR"

  EXISTING=$(get_existing_titles "$REPO")

  # any型をgrepで検出（明示的なany）
  grep -rn ": any[,;\) ]" src/ --include="*.ts" \
  | grep -v "node_modules" \
  | grep -v "\.d\.ts" \
  | grep -v "// eslint-disable" \
  | grep -v "__tests__" \
  | grep -v "\.test\.ts" \
  | grep -v "\.spec\.ts" \
  | grep -v "generated" \
  | awk -F: '!seen[$1]++' \  # ファイル単位で1件に絞る
  | head -20 \
    | while IFS=: read -r file line code; do
        # 既存Issueチェック
        if issue_exists "$EXISTING" "$file"; then
          log "  ⏭️  スキップ（既存Issue）: $file"
          continue
        fi

        log "  🤖 Issue生成中: $file:$line"
        BODY_CONTENT=$(generate_issue_body "$file" "$line" "$code" "any_type")

        TITLE="[Refactor] any型の乱用: ${file##src/}"
        BODY="## 場所\n\`$file:$line\`\n\n## 問題のコード\n\`\`\`typescript\n$code\`\`\`\n\n$BODY_CONTENT\n\n---\n_自動検出: nightly-audit ($DATE)_"

        gh issue create \
          --repo "$REPO" \
          --title "$TITLE" \
          --body "$(echo -e "$BODY")" \
          --label "refactor" \
          2>>"$LOG_FILE" \
          && log "  ✅ 起票: $TITLE" \
          || log "  ⚠️  起票失敗: $TITLE"
      done

  log "✅ [$REPO] any型検出 完了"
done

# ============================================================
# 2. ESLint検出 → Issue起票
# ============================================================
for REPO_INFO in "Hopin-inc/civicship-api:$API_DIR" "Hopin-inc/civicship-portal:$PORTAL_DIR"; do
  REPO="${REPO_INFO%%:*}"
  DIR="${REPO_INFO##*:}"

  log "🔍 [$REPO] ESLint検出中..."
  cd "$DIR"

  EXISTING=$(get_existing_titles "$REPO")

  # ESLintをJSON形式で実行し、errorのみ抽出
  pnpm eslint src/ --format json 2>/dev/null \
    | jq -r '.[] | select(.errorCount > 0) | .filePath as $f | .messages[] | select(.severity == 2) | [$f, (.line|tostring), .ruleId, .message] | join("|")' \
    | head -20 \
    | while IFS='|' read -r file line rule message; do
        # src/以降のパスに整形
        short_file="${file#$DIR/}"

        if issue_exists "$EXISTING" "$short_file"; then
          log "  ⏭️  スキップ（既存Issue）: $short_file"
          continue
        fi

        log "  🤖 Issue生成中: $short_file:$line ($rule)"
        BODY_CONTENT=$(generate_issue_body "$short_file" "$line" "$rule: $message" "eslint")

        TITLE="[Refactor] ESLint: $rule in ${short_file##src/}"
        BODY="## 場所\n\`$short_file:$line\`\n\n## ESLintルール\n\`$rule\`\n\n## エラー内容\n$message\n\n$BODY_CONTENT\n\n---\n_自動検出: nightly-audit ($DATE)_"

        gh issue create \
          --repo "$REPO" \
          --title "$TITLE" \
          --body "$(echo -e "$BODY")" \
          --label "refactor" \
          2>>"$LOG_FILE" \
          && log "  ✅ 起票: $TITLE" \
          || log "  ⚠️  起票失敗: $TITLE"
      done

  log "✅ [$REPO] ESLint検出 完了"
done

# ============================================================
# 3. Dependabotセキュリティアラート → Issue起票
# ============================================================
log "🔒 Dependabotセキュリティアラート監査..."

EXISTING_API=$(get_existing_titles "Hopin-inc/civicship-api")

gh api repos/Hopin-inc/civicship-api/dependabot/alerts \
  --jq '.[] | select(.state == "open") | select(.security_advisory.severity == "critical" or .security_advisory.severity == "high") | [.dependency.package.name, (.security_vulnerability.first_patched_version.identifier // "不明"), .security_advisory.summary] | join("|")' \
  | cat \
  | sort -u \
  | while IFS='|' read -r package fixed_in summary; do
      TITLE="[Security] $package - $summary"

      if echo "$EXISTING_API" | grep -qF "$package"; then
        log "  ⏭️  スキップ（既存Issue）: $package"
        continue
      fi

      log "  🤖 Issue生成中: $package"
      BODY_CONTENT=$(generate_issue_body "$package" "$fixed_in" "$summary" "security")

      BODY="## パッケージ\n\`$package\`\n\n## 修正バージョン\n\`$fixed_in\`\n\n$BODY_CONTENT\n\n---\n_自動検出: nightly-audit ($DATE)_"

      gh issue create \
        --repo "Hopin-inc/civicship-api" \
        --title "$TITLE" \
        --body "$(echo -e "$BODY")" \
        --label "security" \
        2>>"$LOG_FILE" \
        && log "  ✅ 起票: $TITLE" \
        || log "  ⚠️  起票失敗: $TITLE"
    done

log "✅ Dependabotセキュリティアラート監査 完了"

# ============================================================
# 完了通知（Slack）
# ============================================================
SLACK_WEBHOOK="${SLACK_WEBHOOK_URL:-}"
if [ -n "$SLACK_WEBHOOK" ]; then
  API_ISSUES=$(gh issue list --repo Hopin-inc/civicship-api --state open --json number --jq 'length' | cat)
  PORTAL_ISSUES=$(gh issue list --repo Hopin-inc/civicship-portal --state open --json number --jq 'length' | cat)

  curl -s -X POST "$SLACK_WEBHOOK" \
    -H "Content-Type: application/json" \
    -d "{
      \"text\": \"🤖 *nightly-audit 完了* ($DATE)\n• civicship-api: open Issues ${API_ISSUES}件\n• civicship-portal: open Issues ${PORTAL_ISSUES}件\n• ログ: \`$LOG_FILE\`\"
    }" > /dev/null
  log "📤 Slack通知完了"
fi

log "🎉 全監査完了 | ログ: $LOG_FILE"
